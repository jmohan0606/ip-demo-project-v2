# ============================================================
# iPerform Insights & Coaching React UI Environment
# ============================================================
# Copy to .env.local and set NEXT_PUBLIC_API_BASE_URL to your public forwarded URL.

NEXT_PUBLIC_APP_NAME=iPerform Insights & Coaching
NEXT_PUBLIC_APP_ENV=local

# Two API bases (CLAUDE.md Phase 0) — lib/api/client.ts picks the right one per context:
#   Server-side (SSR / route handlers / Playwright / curl checks) — always loopback, always
#   correct from inside the container:
API_BASE_URL_INTERNAL=http://127.0.0.1:8000
#   Browser-side — the PUBLIC forwarded backend URL an external browser must reach. In GitHub
#   Codespaces this is https://<CODESPACE_NAME>-8000.app.github.dev (port 8000 must be Public).
#   Falls back to the internal URL if unset (fine for same-container browsers only).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_ENABLE_LOGIN=false
NEXT_PUBLIC_DEFAULT_PERSONA=Advisor
NEXT_PUBLIC_DEFAULT_SCOPE_TYPE=Firm
NEXT_PUBLIC_DEFAULT_SCOPE_ID=F001
NEXT_PUBLIC_GRAPH_MODE=mock
NEXT_PUBLIC_ENABLE_SCREENSHOT_REVIEW=true
