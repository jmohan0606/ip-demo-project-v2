# iPerform Insights & Coaching — environment template
# Copy to .env (gitignored) and fill in what you have. Every default below runs fully
# offline in mock mode; nothing here is required to boot the demo.
# (CLAUDE.md Section 2 = adapter selection; Section 9.4 = 4-tier TigerGraph adapter; 9.9 = this file.)

# =====================================================================================
# Adapter selection (the three switches that pick real vs mock backends)
# =====================================================================================
# GRAPH_CLIENT_MODE: mock | local_real | real | auto | tiered | mcp
#   mock       = seeded CSV FoundationGraphStore (default, offline)
#   local_real = RealGraphClient against a local Docker TigerGraph (RESTPP)
#   real       = RealGraphClient against the client's TigerGraph
#   auto|tiered|mcp = the Section-9.4 TieredGraphClient (MCP -> pyTigerGraph -> RESTPP -> Mock)
#
# SECTION 14 HANDOVER CONFIG (the client's own hands-on testing — "no mock anywhere"):
#   GRAPH_CLIENT_MODE=real   (or local_real if a local Docker TigerGraph is the target)
#   LLM_CLIENT_MODE=claude   (real Claude; reads ANTHROPIC_API_KEY from env/.env)
#   Verified: the backend BOOTS and SERVES in real+claude. `real` uses the tiered client with
#   automatic fallback to the seeded store when TigerGraph is unreachable (logs the served tier),
#   so it works even before TigerGraph is wired — but point it at a reachable TigerGraph for
#   good latency (the fallback attempts a live connection per request). For a fast fully-offline
#   local demo, keep GRAPH_CLIENT_MODE=mock.
GRAPH_CLIENT_MODE=mock
# LLM_CLIENT_MODE: mock | claude | real | cdao_openai | azure
#   client machine: cdao_openai (PRIMARY, cdao SDK; needs PCL AWS login first) — if it
#   fails, fall back to azure (SmartSDK/Fusion)
#   mock  = deterministic template (default, free)     claude = Anthropic (local quality checks)
#   real  = direct Azure OpenAI SDK (endpoint+key)     azure  = JPMC SmartSDK/Fusion gateway (client)
LLM_CLIENT_MODE=mock
# EMBEDDING_CLIENT_MODE: local | cdao_openai | azure | azure_openai
#   client machine: cdao_openai (PRIMARY, cdao SDK; SAME PCL AWS login as the LLM adapter) — if
#   it fails, fall back to azure (SmartSDK/Fusion). Set EMBEDDING_DIM=3072 for cdao_openai
#   (text-embedding-3-large-1 returns 3072-dim vectors — verified live).
#   local = sentence-transformers (free, 384-dim)      azure = JPMC SmartSDK/Fusion (client)
#   azure_openai = direct Azure OpenAI SDK (endpoint+key)
EMBEDDING_CLIENT_MODE=local
# Guardrails (Security & Governance): input (PII redaction, prompt-injection/jailbreak) + output
# (PII filtering, toxicity, grounding/hallucination). GUARDRAIL_CLIENT_MODE: local (regex/
# heuristic, default) | smartsdk (JPMC SmartSDK EvaluationService in the client env).
GUARDRAIL_CLIENT_MODE=local
GUARDRAILS_ENABLED=true
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Section 11.1: real model tier (ModelClient) + graph-entity vectors (VectorClient) ---
# MODEL_CLIENT_MODE: deterministic (verified scorers/vectors, default) | real (trained
#   XGBoost/GRU/GNN/IsolationForest artifacts; falls back to deterministic per prediction
#   type when no artifact passes its registry quality gate — real is never worse than today)
MODEL_CLIENT_MODE=deterministic
# VECTOR_CLIENT_MODE: local (SQLite cosine, default) | tigergraph (native EMBEDDING/HNSW)
VECTOR_CLIENT_MODE=local
ML_ARTIFACTS_DIR=models/artifacts
ML_TIME_BOX_MINUTES=10                  # hard wall-clock cap per training script
# Section 11.3 outcome-driven learning (Feedback Loop): apply the per-family outcome affinity
# as a bounded +/-10% confidence modifier on recommendations (evidence is always attached
# regardless; priority ranking stays owned by the bandit weight alone).
FL_AFFINITY_IN_CONFIDENCE=true

# =====================================================================================
# App / server / runtime
# =====================================================================================
APP_NAME=iPerform Insights & Coaching
APP_ENV=local
API_HOST=127.0.0.1
API_BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000
# CORS: comma-separated origins. The regex for *.app.github.dev is also applied in code.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
AUTH_MODE=persona_simulation
AGENT_RUNTIME=langgraph
# Persona/scope the UI opens on
DEFAULT_PERSONA=Advisor
DEFAULT_SCOPE_TYPE=Advisor
DEFAULT_SCOPE_ID=A001

# =====================================================================================
# Storage paths / backends (all local by default)
# =====================================================================================
FOUNDATION_DIR=docs/tigergraph_foundation
SQLITE_DB_PATH=data/sqlite/iperform.db
FEATURE_STORE_BACKEND=sqlite
EMBEDDING_BACKEND=chroma
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=iperform_knowledge_base
DOCUMENTS_DIR=data/documents
INGESTION_UPLOAD_DIR=data/uploads

# =====================================================================================
# Anthropic (LLM_CLIENT_MODE=claude; local output-quality spot checks)
# SECURITY: real keys go in .env ONLY (gitignored). Never commit a key.
# =====================================================================================
ANTHROPIC_API_KEY=
# Cheapest tier by design — do not bump without asking (CLAUDE.md Section 2)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# =====================================================================================
# Azure OpenAI (LLM_CLIENT_MODE=real; client site only)
# =====================================================================================
LLM_PROVIDER=openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-06-01
# Plain OpenAI fallbacks (used by some code paths when Azure vars are absent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =====================================================================================
# cdao OpenAI Azure client (JPMC client env) — LLM_CLIENT_MODE=cdao_openai — PRIMARY
# Powers CdaoOpenAILLMClient via `from cdao import openai_azure_client` (cdaosdk-all[openai],
# client-artifactory only; guarded import — the app boots without it in every other mode).
# NO credentials here: cdao authenticates from the ambient PCL AWS login session, which MUST
# be run before starting the app (CLIENT_ENV_SETUP.md §1b). Try this mode FIRST on the client
# machine; fall back to LLM_CLIENT_MODE=azure (SmartSDK below) if it fails.
# =====================================================================================
CDAO_API_VERSION=2024-02-01
# Workspace id from the client console (e.g. 906313) — required for cdao_openai mode (LLM + embed)
CDAO_WORKSPACE_ID=
CDAO_MODEL=gpt-4o-2024-08-06
# Embeddings via the SAME cdao client (EMBEDDING_CLIENT_MODE=cdao_openai — PRIMARY embedding path).
# text-embedding-3-large-1 returns 3072-dim vectors (verified live) — set EMBEDDING_DIM=3072 below.
CDAO_EMBEDDING_MODEL=text-embedding-3-large-1

# =====================================================================================
# SmartSDK / Fusion (JPMC client env) — LLM_CLIENT_MODE=azure (SECONDARY alternate to
# cdao_openai above), EMBEDDING_CLIENT_MODE=azure
# Powers AzureOpenAILLMClient + AzureOpenAIEmbeddingClient via smart_sdk (client-artifactory
# only; guarded import — the app boots without it in every other mode). See SMARTSDK_REFERENCE.md
# and CLIENT_ENV_SETUP.md. NEVER commit real keys/certs — placeholders only here.
# =====================================================================================
# Auth method: key (fusion, primary/confirmed) | certificate (alternate)
AZURE_AUTH_METHOD=key
# Model + deployment (confirmed working values from the client console)
AZURE_MODEL_NAME=gpt-4o-2024-08-06
AZURE_DEPLOYMENT_NAME=gpt-4o-2024-08-06
AZURE_API_KEY=
AZURE_API_VERSION=2024-02-01
# azure_endpoint: optional; defaults to FUSION_BASE_URL when unset (keep /ver2 suffix per console)
AZURE_ENDPOINT=https://llm-multitenancy-exp.jpmchase.net/ver2
# Fusion multitenancy gateway (key auth)
FUSION_BASE_URL=https://llm-multitenancy-exp.jpmchase.net
FUSION_WORKSPACE_ID=
FUSION_ENV=prod
# Certificate auth (AZURE_AUTH_METHOD=certificate) — path to the .pem, plus tenant/client ids
AZURE_CERTIFICATE_PATH=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Embedding deployment (same SmartSDK Model construction, embedding model name)
AZURE_EMBEDDING_MODEL_NAME=text-embedding-3-small
AZURE_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
# Embedding vector dimension — MUST match the active embedding adapter AND the TigerGraph EMBEDDING
# attribute DDL AND the Chroma collection. local sentence-transformers=384; cdao/Azure
# text-embedding-3-large=3072, -3-small=1536. On the client machine with EMBEDDING_CLIENT_MODE=
# cdao_openai (text-embedding-3-large-1), set EMBEDDING_DIM=3072. Changing this requires rebuilding
# the Chroma collection (a fixed-dim collection cannot accept differently-sized vectors).
EMBEDDING_DIM=384

# =====================================================================================
# TigerGraph — legacy RealGraphClient (RESTPP) connection (local_real / real)
# =====================================================================================
TIGERGRAPH_RESTPP_URL=http://localhost:14240/restpp
TIGERGRAPH_GRAPH=iperform_insights_coaching_demo
TIGERGRAPH_HOST=
TIGERGRAPH_RESTPP_PORT=9000
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=
TIGERGRAPH_TOKEN=
TIGERGRAPH_SECRET=
TIGERGRAPH_VERIFY_SSL=true
TIGERGRAPH_TIMEOUT_SECONDS=120
TIGERGRAPH_REST_QUERY_METHOD=post

# =====================================================================================
# TigerGraph — Section-9.4 4-tier adapter (MCP -> pyTigerGraph -> RESTPP -> Mock)
# Used when GRAPH_CLIENT_MODE is auto|tiered|mcp. All optional; mock is the final tier.
# =====================================================================================
# Tier ordering + fallback behaviour
GRAPH_ACCESS_STRATEGY=mcp_first
GRAPH_FALLBACK_ORDER=mcp,rest,mock
GRAPH_EMBEDDING_BACKEND=mock
# Seconds a failed tier is skipped before it is re-probed, and per-tier probe timeout
GRAPH_TIER_COOLDOWN_SECONDS=60
GRAPH_TIER_PROBE_TIMEOUT_SECONDS=5
# pyTigerGraph / MCP connection (Tier 1-2)
# For the client's real remote (e.g. AWS) instance, set TG_HOST to the https URL and
# TG_USE_SSL=true; provide ONE of TG_JWT_TOKEN / TG_API_TOKEN / TG_SECRET. When only a
# secret is set the client calls getToken(secret) automatically. Every connect / token /
# batch-upsert step (and any failure, with full error) is logged to logs/app.log.
#
# ---- CLIENT (JPMC) CONFIRMED VALUES — for GRAPH_CLIENT_MODE=real (SMARTSDK_REFERENCE.md §7-9) ----
# Uncomment these (and comment the local defaults below) on the client machine. TG_SECRET is
# created with `CREATE SECRET iperform_insights_coaching_demo` in GSQL — paste it here, never commit.
#   TG_HOST=https://wh-110ecdf498.svr.us.jpmchase.net
#   TG_GRAPHNAME=iperform_insights_coaching_demo
#   TG_USERNAME=R757680
#   TG_USE_SSL=true
#   TG_GS_PORT=14240
#   TG_SECRET=<paste the CREATE SECRET output here>
# --------------------------------------------------------------------------------------------------
# Local defaults (safe for clone-and-run in mock mode; graph name matches the seeded graph):
TG_HOST=http://127.0.0.1
TG_GRAPHNAME=iperform_insights_coaching_demo
TG_USERNAME=tigergraph
TG_PASSWORD=tigergraph
TG_RESTPP_PORT=9000
TG_GS_PORT=14240
TG_SSL_PORT=443
# SSL/TLS toggles for the remote (Tier 2 pyTigerGraph + Tier 3 RESTPP).
# TG_USE_SSL=true forces the https scheme; TG_VERIFY_SSL=false only for self-signed dev certs.
TG_USE_SSL=false
TG_VERIFY_SSL=true
# Auth precedence: TG_JWT_TOKEN -> TG_API_TOKEN -> TG_SECRET(getToken) -> user/pass.
# One of TG_SECRET / TG_API_TOKEN / TG_JWT_TOKEN for authenticated instances
TG_SECRET=
TG_API_TOKEN=
TG_JWT_TOKEN=
TG_TOKEN_LIFETIME_SECONDS=0
TG_CERT_PATH=
TG_TGCLOUD=false
TG_PROFILE=
# Tier 1 — tigergraph-mcp server (PyPI `tigergraph-mcp`)
TIGERGRAPH_MCP_ENABLED=false
TIGERGRAPH_MCP_COMMAND=tigergraph-mcp
TIGERGRAPH_MCP_ARGS=-vv
TIGERGRAPH_MCP_TRANSPORT=http
TIGERGRAPH_MCP_SERVER_URL=

# =====================================================================================
# Frontend (Next.js) — set these in frontend/.env.local, NOT here. Documented for reference:
#   API_BASE_URL_INTERNAL   = http://127.0.0.1:8000        (SSR / tooling; loopback)
#   NEXT_PUBLIC_API_BASE_URL= https://<codespace>-8000.app.github.dev  (browser; public fwd URL)
# See frontend/.env.local.example.
# =====================================================================================
