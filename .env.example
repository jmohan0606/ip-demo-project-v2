# =====================================================================================
# iPerform V2 — Revenue Trends & AI Commentary — environment template (FIX_SPEC_R4 B4)
# Copy to .env (gitignored) and fill in the <placeholders>. Every key the backend reads
# (app/config/settings.py) is listed here; commented-out keys show their built-in
# defaults — uncomment only to override. The frontend has its own template:
# frontend/.env.local.example (NEXT_PUBLIC_API_BASE_URL etc.).
#
# CLIENT-MACHINE QUICK START (see docs/SOLUTION_GUIDE.md Chapter 9 for the full runbook):
#   GRAPH_CLIENT_MODE=real   DATA_SET=real   LLM_CLIENT_MODE=claude   + the TG_* block
# CODESPACE / OFFLINE DEMO:
#   GRAPH_CLIENT_MODE=local  DATA_SET=sample LLM_CLIENT_MODE=mock
# =====================================================================================

# ------------------------------------------------------------------- core modes (CLAUDE.md §5)
# real = TigerGraph tier 1; local = SQLite/local-store tier 2. In real mode a query served
# by the fallback is LOGGED (never silent) and the env-health screen goes red.
GRAPH_CLIENT_MODE=real
# claude = Anthropic API (needs ANTHROPIC_API_KEY); mock = deterministic template text.
LLM_CLIENT_MODE=claude
# Which CSV set the ingestion screen loads: real = data/real, sample = data/sample.
DATA_SET=real
# Commentary is generated in batch and stored — NEVER on page load. Do not change.
COMMENTARY_MODE=stored

# ------------------------------------------------------------------- credited-revenue config (R1)
# Product grid types that count toward credited revenue (comma-separated). Relaxing to
# "PRODUCT_TYPE,PAY_TYPE_SUMMARY" changes behaviour with no code change.
CREDITED_GRID_TYPES=PRODUCT_TYPE
# The client's 90-day rule: rows with days_to_process above this stay in Total, out of Credited.
MAX_PROCESSING_DAYS=90
# R6 A2 — account-presence persistence: an account counts as LOST only after this many
# consecutive months of no activity (symmetric for NEW). Recurring-class groups only.
ACCOUNT_ABSENCE_MONTHS=2

# ------------------------------------------------------------------- LLM (writer + judge)
ANTHROPIC_API_KEY=<sk-ant-...>
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001      # commentary writer
# JUDGE_MODEL=claude-sonnet-5                    # independent LLM-as-judge (R5) — different model
# JUDGE_ENABLED=true                             # advisory only; guardrails remain the gate
# GUARDRAILS_ENABLED=true
# GUARDRAIL_CLIENT_MODE=local                    # local | smartsdk (client env)

# ------------------------------------------------------------------- TigerGraph (tier 1)
# TG_* uses the official tigergraph-mcp naming; the same values drive the MCP server,
# pyTigerGraph and RESTPP tiers. Auth precedence: JWT -> API token -> getToken(secret)
# -> username/password.
TG_HOST=https://<your-tigergraph-host>
TG_GRAPHNAME=iperform_v2_revenue
TG_USERNAME=<user>
TG_PASSWORD=<password>
TG_SECRET=<secret-if-used>
# TG_API_TOKEN=
# TG_JWT_TOKEN=
# TG_TOKEN_LIFETIME_SECONDS=0                    # 0 = server default
# TG_RESTPP_PORT=9000
# TG_GS_PORT=14240
# TG_SSL_PORT=443
# TG_USE_SSL=false                               # true when TG_HOST is https://
# TG_VERIFY_SSL=true                             # false only for self-signed dev certs
# GRAPH_TIER_COOLDOWN_SECONDS=60
# GRAPH_TIER_PROBE_TIMEOUT_SECONDS=10
# GRAPH_LOAD_BATCH_SIZE=500

# Legacy TIGERGRAPH_* names (older adapters read these; keep in sync with TG_* if set):
# TIGERGRAPH_HOST=
# TIGERGRAPH_USERNAME=
# TIGERGRAPH_PASSWORD=
# TIGERGRAPH_SECRET=
# TIGERGRAPH_TOKEN=
# TIGERGRAPH_GRAPH=iperform_v2_revenue
# TIGERGRAPH_SCHEMA_PREFIX=phx_dm_v2_
# TIGERGRAPH_RESTPP_URL=http://localhost:14240/restpp
# TIGERGRAPH_VERIFY_SSL=true
# TIGERGRAPH_TIMEOUT_SECONDS=120
# TIGERGRAPH_REST_TIMEOUT_SECONDS=30

# TigerGraph MCP transport (tier-1 option; defaults are fine when unused):
# TIGERGRAPH_MCP_URL=
# TIGERGRAPH_MCP_TOKEN=
# TIGERGRAPH_MCP_TRANSPORT=http
# TIGERGRAPH_MCP_API_KEY=
# TIGERGRAPH_MCP_AUTH_HEADER=Authorization
# TIGERGRAPH_MCP_AUTH_SCHEME=Bearer
# TIGERGRAPH_MCP_TIMEOUT_SECONDS=30
# TIGERGRAPH_MCP_CLIENT_MODE=streamable_http
# TIGERGRAPH_MCP_STDIO_COMMAND=python
# TIGERGRAPH_MCP_STDIO_ARGS=-m,tigergraph_mcp
# TIGERGRAPH_MCP_USE_LIBRARY_CLIENT=true
# TIGERGRAPH_MCP_LIST_TOOLS_ON_HEALTH=true
# TIGERGRAPH_MCP_TOOL_HEALTH_CHECK=health_check
# TIGERGRAPH_MCP_TOOL_QUERY_GRAPH=query_graph
# TIGERGRAPH_MCP_TOOL_RUN_INSTALLED_QUERY=run_installed_query
# TIGERGRAPH_MCP_TOOL_UPSERT_VERTEX=upsert_vertex
# TIGERGRAPH_MCP_TOOL_UPSERT_EDGE=upsert_edge
# TIGERGRAPH_MCP_TOOL_RUN_GSQL=run_gsql
# TIGERGRAPH_MCP_TOOL_GET_SCHEMA=get_schema
# GRAPH_ACCESS_STRATEGY=mcp_rest_mock
# ENABLE_TIGERGRAPH_MCP=true
# ENABLE_TIGERGRAPH_REST_FALLBACK=true
# ENABLE_LOCAL_MOCK_FALLBACK=true

# ------------------------------------------------------------------- ports / addresses
# Backend binds 0.0.0.0 by default so Codespaces port-forwarding works; on a client
# machine set API_HOST=127.0.0.1 for loopback-only if desired.
# API_HOST=0.0.0.0
API_PORT=8001
# API_BASE_URL=http://127.0.0.1:8001
# STREAMLIT_PORT=8501

# ------------------------------------------------------------------- app identity / logging
# APP_NAME=iPerform V2 — Revenue Trends & AI Commentary
# APP_ENV=local
# APP_VERSION=2.0.0
# LOG_LEVEL=INFO
# LOG_SINK=file                                  # file | stdout | cloudwatch
# LOG_JSON=true
# LOG_DIR=logs
# LOG_FILE_NAME=app.log
# LOG_ROTATE_MAX_BYTES=10485760
# LOG_ROTATE_BACKUP_COUNT=5
# LOG_CLOUDWATCH_GROUP=/iperform/insights-coaching
# LOG_CLOUDWATCH_STREAM=
# AWS_REGION=
# ENABLE_DIAGNOSTICS_ROUTES=true                 # set false in prod

# ------------------------------------------------------------------- local paths
# SQLITE_DB_PATH=./data/feature_store/iperform_features.db
# CHROMA_PATH=./data/chroma
# UPLOADS_PATH=./data/uploads
# CHECKPOINTS_PATH=./data/checkpoints
# EXPORTS_PATH=./data/exports
# DOCUMENTS_PATH=./data/documents
# FOUNDATION_DIR=docs/tigergraph_foundation      # schema/data/queries source of truth

# ------------------------------------------------------------------- retained infra switches
# Settings below are read by retained shared infrastructure (embedding/vector/state
# adapters, alternate LLM gateways). The V2 revenue app runs with these defaults; they
# are listed so the template covers every key settings.py reads (B4). Change only if
# you are wiring the corresponding client-environment adapter.
# EMBEDDING_CLIENT_MODE=local                    # local | cdao_openai | azure | azure_openai
# LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIM=384                              # 1536 azure small / 3072 cdao large
# MODEL_CLIENT_MODE=deterministic                # deterministic | real
# STATE_STORE_MODE=tigergraph                    # tigergraph | sqlite
# VECTOR_CLIENT_MODE=local                       # local | tigergraph
# ML_ARTIFACTS_DIR=models/artifacts
# ML_TIME_BOX_MINUTES=10
# FL_AFFINITY_IN_CONFIDENCE=true
# RERANK_CLIENT_MODE=local                       # local | cohere
# COHERE_API_KEY=
# COHERE_RERANK_MODEL=rerank-english-v3.0
# CONTEXT_RERANK_TOP_K=8
# ENABLE_OPENAI=true
# ENABLE_CHROMA=true

# OpenAI / Azure OpenAI (only if an alternate LLM/embedding gateway is selected):
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-06-01

# cdao OpenAI (client env; ambient PCL AWS login supplies auth):
# CDAO_API_VERSION=2024-02-01
# CDAO_WORKSPACE_ID=
# CDAO_MODEL=gpt-4o-2024-08-06
# CDAO_EMBEDDING_MODEL=text-embedding-3-large-1

# SmartSDK / Fusion (client env; LLM_CLIENT_MODE=azure):
# AZURE_AUTH_METHOD=key                          # key | certificate
# AZURE_MODEL_NAME=gpt-4o-2024-08-06
# AZURE_DEPLOYMENT_NAME=gpt-4o-2024-08-06
# AZURE_API_KEY=
# AZURE_API_VERSION=2024-02-01
# AZURE_ENDPOINT=
# FUSION_BASE_URL=
# FUSION_WORKSPACE_ID=
# FUSION_ENV=prod
# AZURE_CERTIFICATE_PATH=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_EMBEDDING_MODEL_NAME=text-embedding-3-small
# AZURE_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
