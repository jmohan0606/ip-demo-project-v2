    LOAD f_balance_in_month TO EDGE phx_dm_v2_balance_in_month VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_change_for_advisor TO EDGE phx_dm_v2_change_for_advisor VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_change_for_group TO EDGE phx_dm_v2_change_for_group VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_change_from_month TO EDGE phx_dm_v2_change_from_month VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_change_to_month TO EDGE phx_dm_v2_change_to_month VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_driver_of_change TO EDGE phx_dm_v2_driver_of_change VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_driver_has_cause TO EDGE phx_dm_v2_driver_has_cause VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_driver_for_group TO EDGE phx_dm_v2_driver_for_group VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_commentary_for_advisor TO EDGE phx_dm_v2_commentary_for_advisor VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_commentary_from_month TO EDGE phx_dm_v2_commentary_from_month VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_commentary_to_month TO EDGE phx_dm_v2_commentary_to_month VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
