    DEFINE FILENAME f_reason_code = "./vertices/reason_code.csv";
    DEFINE FILENAME f_revenue_transaction = "./vertices/revenue_transaction.csv";
    DEFINE FILENAME f_monthly_product_revenue = "./vertices/monthly_product_revenue.csv";
    DEFINE FILENAME f_account_month_balance = "./vertices/account_month_balance.csv";
    DEFINE FILENAME f_revenue_change = "./vertices/revenue_change.csv";
    DEFINE FILENAME f_revenue_driver = "./vertices/revenue_driver.csv";
    DEFINE FILENAME f_commentary_version = "./vertices/commentary_version.csv";
    DEFINE FILENAME f_commentary = "./vertices/commentary.csv";
    DEFINE FILENAME f_commentary_evaluation = "./vertices/commentary_evaluation.csv";
    DEFINE FILENAME f_evidence = "./vertices/evidence.csv";
