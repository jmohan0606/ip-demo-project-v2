    DEFINE FILENAME f_driver_for_group = "./edges/driver_for_group.csv";
    DEFINE FILENAME f_commentary_for_advisor = "./edges/commentary_for_advisor.csv";
    DEFINE FILENAME f_commentary_from_month = "./edges/commentary_from_month.csv";
    DEFINE FILENAME f_commentary_to_month = "./edges/commentary_to_month.csv";
    DEFINE FILENAME f_commentary_in_version = "./edges/commentary_in_version.csv";
    DEFINE FILENAME f_commentary_cites_driver = "./edges/commentary_cites_driver.csv";
    DEFINE FILENAME f_evidence_for_driver = "./edges/evidence_for_driver.csv";
