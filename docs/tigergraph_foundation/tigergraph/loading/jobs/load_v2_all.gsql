    DEFINE FILENAME f_anomaly_for_advisor = "./edges/anomaly_for_advisor.csv";
    DEFINE FILENAME f_anomaly_in_scan = "./edges/anomaly_in_scan.csv";
    DEFINE FILENAME f_anomaly_cites_driver = "./edges/anomaly_cites_driver.csv";

    LOAD f_advisor TO VERTEX phx_dm_v2_advisor VALUES ($"advisor_sid", $"advisor_name", $"rep_code", $"branch_cd", $"standard_id", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_month TO VERTEX phx_dm_v2_month VALUES ($"month_id", $"year", $"month_no", $"month_name", $"quarter", $"start_dt", $"end_dt", $"calendar_days", $"billable_days", $"prior_month_id", $"index_return", $"is_current", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_revenue_class TO VERTEX phx_dm_v2_revenue_class VALUES ($"class_id", $"class_name", $"display_order", $"data_source") USING HEADER="true", SEPARATOR=",";
