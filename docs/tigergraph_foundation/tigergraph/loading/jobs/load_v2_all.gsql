    LOAD f_account TO VERTEX phx_dm_v2_account VALUES ($"account_no", $"account_typ", $"wrap_flg", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_driver_cause TO VERTEX phx_dm_v2_driver_cause VALUES ($"cause_id", $"cause_name", $"cause_description", $"default_data_source", $"display_order", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_reason_code TO VERTEX phx_dm_v2_reason_code VALUES ($"reason_code", $"description", $"ui_mapping", $"owned_by", $"eligibility", $"include_in_credited", $"incentive_eligible", $"display_order", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_revenue_transaction TO VERTEX phx_dm_v2_revenue_transaction VALUES ($"txn_id", $"trade_ref_no", $"split_seq_no", $"advisor_sid", $"month_id", $"product_id", $"account_no", $"trade_dt", $"proc_dt", $"credited_amt", $"pre_split_amt", $"split_pct", $"client_rate_bps", $"std_tier_rate", $"concession_type", $"discount_amt", $"eff_disc_pct", $"avg_balance_amt", $"file_key", $"trade_description", $"rev_nature", $"reason_cd", $"rm_sid", $"cs_sid", $"revenue_eligibility", $"incentive_eligible", $"days_to_process", $"posting_month_id", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_monthly_product_revenue TO VERTEX phx_dm_v2_monthly_product_revenue VALUES ($"mpr_id", $"advisor_sid", $"month_id", $"group_id", $"line_id", $"class_id", $"revenue", $"txn_count", $"account_count", $"avg_rate_bps", $"recurring_amt", $"one_time_amt", $"total_revenue", $"non_credited_amt", $"excluded_amt", $"late_excluded_amt", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_account_month_balance TO VERTEX phx_dm_v2_account_month_balance VALUES ($"balance_id", $"account_no", $"month_id", $"avg_billable_assets", $"effective_fee_bps", $"billable_days", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_revenue_change TO VERTEX phx_dm_v2_revenue_change VALUES ($"change_id", $"advisor_sid", $"from_month_id", $"to_month_id", $"group_id", $"from_revenue", $"to_revenue", $"change_amt", $"change_pct", $"direction", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_revenue_driver TO VERTEX phx_dm_v2_revenue_driver VALUES ($"driver_id", $"change_id", $"cause_id", $"group_id", $"contribution_amt", $"contribution_pct", $"direction", $"rank", $"inputs_json", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_commentary_version TO VERTEX phx_dm_v2_commentary_version VALUES ($"version_id", $"version_no", $"generated_at", $"model", $"prompt_version", $"data_snapshot_dt", $"status", $"advisor_count", $"transition_count", $"blocked_count", $"notes", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_commentary TO VERTEX phx_dm_v2_commentary VALUES ($"commentary_id", $"version_id", $"advisor_sid", $"from_month_id", $"to_month_id", $"headline", $"narrative_text", $"bullets_json", $"status", $"blocked_reason", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_commentary_evaluation TO VERTEX phx_dm_v2_commentary_evaluation VALUES ($"evaluation_id", $"commentary_id", $"version_id", $"judge_model", $"faithfulness_score", $"hallucination_flag", $"completeness_score", $"clarity_score", $"verdict", $"reasoning", $"evaluated_at", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_evidence TO VERTEX phx_dm_v2_evidence VALUES ($"evidence_id", $"driver_id", $"finding_text", $"calc_json", $"source_records_json", $"lineage_json", $"checks_json", $"gsql_query_name", $"gsql_params_json", $"gsql_result_json", $"source_sql", $"source_table", $"source_row_count", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_anomaly TO VERTEX phx_dm_v2_anomaly VALUES ($"anomaly_id", $"advisor_sid", $"from_month_id", $"to_month_id", $"rule_id", $"severity", $"title", $"detail_text", $"metrics_json", $"threshold_json", $"impact_amt", $"group_id", $"scan_id", $"detected_at", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_anomaly_scan TO VERTEX phx_dm_v2_anomaly_scan VALUES ($"scan_id", $"started_at", $"advisors_reviewed", $"transitions_reviewed", $"flagged_count", $"thresholds_json", $"status", $"data_source") USING HEADER="true", SEPARATOR=",";
    LOAD f_product_in_group TO EDGE phx_dm_v2_product_in_group VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_group_in_line TO EDGE phx_dm_v2_group_in_line VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_line_in_class TO EDGE phx_dm_v2_line_in_class VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
    LOAD f_txn_for_advisor TO EDGE phx_dm_v2_txn_for_advisor VALUES ($"from_id", $"to_id") USING HEADER="true", SEPARATOR=",";
