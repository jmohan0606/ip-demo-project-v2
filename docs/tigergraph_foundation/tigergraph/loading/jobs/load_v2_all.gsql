    DEFINE FILENAME f_txn_in_month = "./edges/txn_in_month.csv";
    DEFINE FILENAME f_txn_for_product = "./edges/txn_for_product.csv";
    DEFINE FILENAME f_txn_for_account = "./edges/txn_for_account.csv";
    DEFINE FILENAME f_txn_has_reason = "./edges/txn_has_reason.csv";
